{
  "name": "settlepass",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.2.1",
    "@settlepass/api-contracts": "workspace:*"
  },
  "devDependencies": {
    "turbo": "2.3.3",
    "typescript": "5.7.3",
    "prettier": "3.4.2",
    "prisma": "6.2.1",
    "tsx": "4.19.2"
  }
}