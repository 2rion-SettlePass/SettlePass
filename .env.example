# SettlePass Phase 1 — environment template. Copy to .env and adjust for your machine.
# Only DATABASE_URL is strictly required; all others have safe defaults.
# Authoritative schema/validation: apps/api/src/config/env.validation.ts

NODE_ENV=development
PORT=4000

# Postgres (local dev). Matches the docker run credentials in docs/engineering/PROJECT_STATUS.md
DATABASE_URL="postgresql://user:password@localhost:5432/settlepass?schema=public"

# --- Identity (mock-first is the Phase 1 default) ---
IDENTITY_MODE=CX_MOCK_MODE
FOREIGNER_CLAIM_MODE=MOCK
# OMNIONE_CX_BASE_URL=
# OMNIONE_CX_PROVIDER_ID=
# OMNIONE_CX_FOREIGNER_PROVIDER_ID=

# --- Contract OCR (mock-first) ---
CLOVA_OCR_MODE=mock
# CLOVA_OCR_INVOKE_URL=
# CLOVA_OCR_SECRET=

# --- AI Review (mock-first; real = GLM/Zhipu or any OpenAI-compatible API) ---
AI_REVIEW_MODE=mock
# For GLM (Zhipu) real mode, set:
#   AI_REVIEW_MODE=real
#   AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4   # international: https://api.z.ai/api/paas/v4
#   AI_API_KEY=<your GLM api key>                       # raw key as Bearer (no JWT)
#   AI_MODEL=glm-4.6                                    # or glm-4-flash / glm-4.5-air, etc.
# AI_BASE_URL=
# AI_API_KEY=
AI_MODEL=gpt-4.1-mini

# --- Hashing (dev salt only — replace in real deployments) ---
HASH_SECRET_SALT=phase1-dev-salt

# --- Uploaded contract file temp TTL (seconds) ---
FILE_TEMP_TTL_SECONDS=3600
